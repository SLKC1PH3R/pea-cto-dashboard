{
  "manifest_version": 3,
  "name": "Folio",
  "short_name": "Folio",
  "version": "1.0.0",
  "description": "Suivi rapide de ton portefeuille PEA/CTO Folio — valeur, performance du jour, top gain/perte.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Folio",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://folio.digitalstack.cloud/*"]
}
