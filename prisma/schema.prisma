// Schéma Prisma — Dashboard PEA / CTO
// Projet solo, multi-comptes, dashboard customisable

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// UTILISATEUR (auth email/password ou Google)
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  // Null pour les comptes créés via Google (pas de mot de passe local)
  passwordHash  String?
  name          String?
  avatarColor   String?
  avatarUrl     String?   @db.Text
  onboarded     Boolean   @default(false)
  goalAmount    Decimal?  @db.Decimal(18, 2)
  birthDate     DateTime?
  fireAge       Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  dashboardLayouts DashboardLayout[]
  dcaRules        DcaRule[]
  watchlistItems  WatchlistItem[]
  apiTokens       ApiToken[]
}

// ============================================================
// TOKENS D'ACCÈS PERSONNELS (ex: extension navigateur)
// ============================================================

// L'extension navigateur n'a pas accès au cookie de session Next-Auth (autre
// contexte d'origine) — elle s'authentifie donc avec un token dédié, envoyé
// en "Authorization: Bearer ..." sur /api/extension. Seul le hash est stocké
// (même logique que passwordHash) : le token brut n'est affiché qu'une fois,
// à sa création, côté UI.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  label      String    @default("Extension navigateur")
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// ============================================================
// LISTE DE SUIVI (actions/ETF à suivre sans forcément les détenir)
// ============================================================

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker    String
  name      String?
  // Cours saisi manuellement, en repli quand ni Finnhub ni boursorama.com
  // ne couvrent ce ticker (ex: ETC sur la London Stock Exchange).
  manualPrice   Decimal?  @db.Decimal(18, 4)
  manualPriceAt DateTime?
  createdAt DateTime @default(now())

  @@unique([userId, ticker])
}

// ============================================================
// COMPTES
// ============================================================

enum AccountType {
  PEA
  CTO
}

enum Broker {
  BOURSORAMA
  TRADE_REPUBLIC
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // ex: "PEA Boursorama"
  type      AccountType
  broker    Broker? // précisé plus tard, depuis la page d'import
  currency  String      @default("EUR")
  openedAt  DateTime   @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  deposits    Deposit[]
  fees        Fee[]
  positions   Position[]
  dcaRules    DcaRule[]

  @@index([type])
  @@index([userId])
}

// ============================================================
// MOUVEMENTS DE CASH
// ============================================================

model Deposit {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(18, 2) // positif = dépôt, négatif = retrait
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([accountId, date])
}

enum FeeType {
  COURTAGE
  GESTION
  CHANGE
  GARDE
  AUTRE
}

model Fee {
  id         String      @id @default(cuid())
  accountId  String
  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       FeeType
  amount     Decimal     @db.Decimal(18, 2)
  date       DateTime
  note        String?
  // Optionnel : lier le frais à une transaction précise (frais de courtage)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  createdAt  DateTime    @default(now())

  @@index([accountId, date])
}

// ============================================================
// ACTIFS
// ============================================================

enum AssetType {
  ACTION
  ETF_DISTRIBUANT
  ETF_CAPITALISANT
}

model Asset {
  id              String     @id @default(cuid())
  ticker          String     @unique // ticker Finnhub
  isin            String?
  name            String
  sector          String?
  region          String?
  currency        String
  assetType       AssetType
  benchmarkTicker String? // ticker de l'ETF de référence pour comparaison
  // Cours saisi manuellement, en repli quand Finnhub ne couvre pas la place
  // de cotation (ex: ETF Euronext sur un plan gratuit) — saisi par
  // l'utilisateur, mis à jour à la main, jamais une donnée fabriquée.
  manualPrice     Decimal?   @db.Decimal(18, 4)
  manualPriceAt   DateTime?
  createdAt       DateTime   @default(now())

  positions Position[]
  dcaRules  DcaRule[]

  @@index([assetType])
}

// ============================================================
// POSITIONS / TRANSACTIONS / DIVIDENDES
// ============================================================

model Position {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  createdAt DateTime @default(now())

  transactions Transaction[]
  dividends    Dividend[]

  @@unique([accountId, assetId]) // une seule position par actif par compte
}

enum TxType {
  BUY
  SELL
}

enum TxStatus {
  CONFIRMED  // transaction réelle, confirmée (import PDF ou saisie manuelle validée)
  PROJECTED  // générée automatiquement par une DcaRule, pas encore confirmée
}

model Transaction {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  type       TxType
  status     TxStatus @default(CONFIRMED)
  quantity   Decimal  @db.Decimal(18, 6)
  price      Decimal  @db.Decimal(18, 4) // prix unitaire dans la devise de l'actif
  fees       Decimal  @db.Decimal(18, 2) @default(0)
  date       DateTime
  note       String?
  // Si la transaction provient d'une règle DCA (projetée ou confirmée à partir d'une projection)
  dcaRuleId  String?
  dcaRule    DcaRule? @relation(fields: [dcaRuleId], references: [id])
  // Si importée depuis un PDF, on garde une trace pour éviter les doublons
  sourceDocument String? // ex: nom du fichier PDF original
  // Référence d'ordre Boursorama ("Référence : 010115845027"), présente sur
  // les avis d'opéré — identifiant le plus fiable pour détecter un doublon
  // d'import, car deux ordres distincts du même jour peuvent avoir exactement
  // la même quantité/le même montant (ex: un gros ordre exécuté en plusieurs
  // fois au même cours).
  externalRef String?
  createdAt  DateTime @default(now())

  relatedFees Fee[]

  @@index([positionId, date])
  @@index([dcaRuleId])
}

model Dividend {
  id          String   @id @default(cuid())
  positionId  String
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  grossAmount Decimal  @db.Decimal(18, 2)
  netAmount   Decimal  @db.Decimal(18, 2)
  withholding Decimal  @db.Decimal(18, 2) @default(0) // retenue à la source
  currency    String
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([positionId, date])
}

// ============================================================
// PLANS D'INVESTISSEMENT PROGRAMMÉ (DCA)
// ============================================================

enum DcaFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model DcaRule {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset        @relation(fields: [assetId], references: [id])
  amount        Decimal      @db.Decimal(18, 2) // montant investi à chaque exécution, dans la devise du compte
  frequency     DcaFrequency
  firstExecution DateTime
  active        Boolean      @default(true)
  note          String?      // ex: référence du plan ("d356-159c" chez Trade Republic)
  createdAt     DateTime     @default(now())

  transactions Transaction[] // transactions confirmées ou projetées issues de cette règle

  @@index([userId])
  @@index([accountId])
}

// ============================================================
// PRIX HISTORIQUES (cache local Finnhub)
// ============================================================

model PriceHistory {
  id        String   @id @default(cuid())
  ticker    String
  date      DateTime
  close     Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())

  @@unique([ticker, date])
  @@index([ticker])
}

// ============================================================
// DASHBOARD CUSTOMISABLE
// ============================================================

model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Mon dashboard")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  widgets Widget[]

  @@index([userId])
}

enum WidgetType {
  TOTAL_VALUE
  PNL_CHART
  ALLOCATION_SECTOR
  ALLOCATION_GEO
  ALLOCATION_CURRENCY
  BENCHMARK_COMPARISON
  FEES_SUMMARY
  DIVIDEND_CALENDAR
  POSITIONS_TABLE
  DEPOSITS_HISTORY
  STOCK_VS_ETF
}

model Widget {
  id       String          @id @default(cuid())
  layoutId String
  layout   DashboardLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  type     WidgetType
  x        Int
  y        Int
  w        Int
  h        Int
  config   Json? // ex: { "accountId": "...", "period": "1Y" }

  @@index([layoutId])
}
