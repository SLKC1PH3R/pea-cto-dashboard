// Schéma Prisma — Dashboard PEA / CTO
// Projet solo, multi-comptes, dashboard customisable

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// COMPTES
// ============================================================

enum AccountType {
  PEA
  CTO
}

enum Broker {
  BOURSORAMA
  TRADE_REPUBLIC
}

model Account {
  id        String      @id @default(cuid())
  name      String // ex: "PEA Boursorama"
  type      AccountType
  broker    Broker
  currency  String      @default("EUR")
  openedAt  DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  deposits    Deposit[]
  fees        Fee[]
  positions   Position[]

  @@index([type])
}

// ============================================================
// MOUVEMENTS DE CASH
// ============================================================

model Deposit {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(18, 2) // positif = dépôt, négatif = retrait
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([accountId, date])
}

enum FeeType {
  COURTAGE
  GESTION
  CHANGE
  GARDE
  AUTRE
}

model Fee {
  id         String      @id @default(cuid())
  accountId  String
  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       FeeType
  amount     Decimal     @db.Decimal(18, 2)
  date       DateTime
  note        String?
  // Optionnel : lier le frais à une transaction précise (frais de courtage)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  createdAt  DateTime    @default(now())

  @@index([accountId, date])
}

// ============================================================
// ACTIFS
// ============================================================

enum AssetType {
  ACTION
  ETF_DISTRIBUANT
  ETF_CAPITALISANT
}

model Asset {
  id              String     @id @default(cuid())
  ticker          String     @unique // ticker Finnhub
  isin            String?
  name            String
  sector          String?
  region          String?
  currency        String
  assetType       AssetType
  benchmarkTicker String? // ticker de l'ETF de référence pour comparaison
  createdAt       DateTime   @default(now())

  positions Position[]

  @@index([assetType])
}

// ============================================================
// POSITIONS / TRANSACTIONS / DIVIDENDES
// ============================================================

model Position {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  createdAt DateTime @default(now())

  transactions Transaction[]
  dividends    Dividend[]

  @@unique([accountId, assetId]) // une seule position par actif par compte
}

enum TxType {
  BUY
  SELL
}

model Transaction {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  type       TxType
  quantity   Decimal  @db.Decimal(18, 6)
  price      Decimal  @db.Decimal(18, 4) // prix unitaire dans la devise de l'actif
  fees       Decimal  @db.Decimal(18, 2) @default(0)
  date       DateTime
  note       String?
  createdAt  DateTime @default(now())

  relatedFees Fee[]

  @@index([positionId, date])
}

model Dividend {
  id          String   @id @default(cuid())
  positionId  String
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  grossAmount Decimal  @db.Decimal(18, 2)
  netAmount   Decimal  @db.Decimal(18, 2)
  withholding Decimal  @db.Decimal(18, 2) @default(0) // retenue à la source
  currency    String
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([positionId, date])
}

// ============================================================
// PRIX HISTORIQUES (cache local Finnhub)
// ============================================================

model PriceHistory {
  id        String   @id @default(cuid())
  ticker    String
  date      DateTime
  close     Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())

  @@unique([ticker, date])
  @@index([ticker])
}

// ============================================================
// DASHBOARD CUSTOMISABLE
// ============================================================

model DashboardLayout {
  id        String   @id @default(cuid())
  name      String   @default("Mon dashboard")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  widgets Widget[]
}

enum WidgetType {
  TOTAL_VALUE
  PNL_CHART
  ALLOCATION_SECTOR
  ALLOCATION_GEO
  ALLOCATION_CURRENCY
  BENCHMARK_COMPARISON
  FEES_SUMMARY
  DIVIDEND_CALENDAR
  POSITIONS_TABLE
  DEPOSITS_HISTORY
  STOCK_VS_ETF
}

model Widget {
  id       String          @id @default(cuid())
  layoutId String
  layout   DashboardLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  type     WidgetType
  x        Int
  y        Int
  w        Int
  h        Int
  config   Json? // ex: { "accountId": "...", "period": "1Y" }

  @@index([layoutId])
}
